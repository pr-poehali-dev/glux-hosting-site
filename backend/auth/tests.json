{
  "tests": [
    {
      "name": "CORS preflight",
      "method": "OPTIONS",
      "path": "/",
      "expectedStatus": 200
    },
    {
      "name": "Login with wrong credentials",
      "method": "POST",
      "path": "/?action=login",
      "body": {"login": "nobody", "password": "wrong"},
      "expectedStatus": 401,
      "bodyMatcher": "partial"
    },
    {
      "name": "Register missing fields",
      "method": "POST",
      "path": "/?action=register",
      "body": {"username": ""},
      "expectedStatus": 400,
      "bodyMatcher": "partial"
    }
  ]
}
